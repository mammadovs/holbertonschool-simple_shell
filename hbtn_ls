#!/bin/bash
# hbtn_ls — простой исполняемый файл для тестов Holberton
# принимает один аргумент — директорию для вывода
# корректно работает с пробелами

if [ -z "$1" ]; then
    echo "Usage: $0 directory"
    exit 1
fi

# проверяем, что это директория
if [ -d "$1" ]; then
    # используем ls с опцией -1 для вывода по одному на строку
    ls -1 "$1"
else
    echo "$1: not a directory"
    exit 1
fi
